# Backend
RESOURCE_COMMUNITY_GO_APP_PORT=3000
RESOURCE_COMMUNITY_GO_ENABLE_PPROF=false
RESOURCE_COMMUNITY_GO_SLOW_REQUEST_THRESHOLD_MS=500
RESOURCE_COMMUNITY_GO_DATABASE_DSN=resource_community_go:resource_community_go@tcp(mysql:3306)/resource_community_go?charset=utf8mb4&parseTime=True&loc=Local
RESOURCE_COMMUNITY_GO_REDIS_ADDR=redis:6379
RESOURCE_COMMUNITY_GO_REDIS_PASSWORD=
RESOURCE_COMMUNITY_GO_REDIS_DB=0
RESOURCE_COMMUNITY_GO_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RESOURCE_COMMUNITY_GO_RABBITMQ_EXCHANGE=resource_community_go.async
RESOURCE_COMMUNITY_GO_RABBITMQ_QUEUE=resource_community_go.async.jobs
RESOURCE_COMMUNITY_GO_JWT_SECRET=change-me-in-production
RESOURCE_COMMUNITY_GO_UPLOAD_DIR=uploads

# Frontend
VITE_API_BASE_URL=/api
