# Backend
EXCHANGEAPP_APP_PORT=3000
EXCHANGEAPP_ENABLE_PPROF=false
EXCHANGEAPP_SLOW_REQUEST_THRESHOLD_MS=500
EXCHANGEAPP_DATABASE_DSN=exchangeapp:exchangeapp@tcp(mysql:3306)/exchangeapp?charset=utf8mb4&parseTime=True&loc=Local
EXCHANGEAPP_REDIS_ADDR=redis:6379
EXCHANGEAPP_REDIS_PASSWORD=
EXCHANGEAPP_REDIS_DB=0
EXCHANGEAPP_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
EXCHANGEAPP_RABBITMQ_EXCHANGE=exchangeapp.async
EXCHANGEAPP_RABBITMQ_QUEUE=exchangeapp.async.jobs
EXCHANGEAPP_JWT_SECRET=change-me-in-production
EXCHANGEAPP_UPLOAD_DIR=uploads

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
